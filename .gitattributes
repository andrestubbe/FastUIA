# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.java text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.def text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.bat text eol=crlf
*.sh text eol=lf

# Binary files
*.dll binary
*.so binary
*.dylib binary
*.jar binary
*.class binary
